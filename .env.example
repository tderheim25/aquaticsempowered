# Local dev (browser)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Public app URL for invitation emails, magic links, and auth redirects.
# Set to your deployed site in production and when sending real emails from local dev.
NEXT_PUBLIC_APP_URL=https://aquaticsempowered.vercel.app

# REQUIRED (MVP)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PROJECT_ID=

# REQUIRED (MVP)
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# OPTIONAL (post-MVP — feat/stripe-checkout)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_FOUNDER_ANNUAL=

# OPTIONAL (Phase 3)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# OPTIONAL (recommended)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# Dev-only: enable /dev/sentry-test page in production (default off)
NEXT_PUBLIC_ENABLE_DEV_ROUTES=false
