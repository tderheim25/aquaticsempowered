# Local dev (browser)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Public app URL for invitation emails, magic links, and auth redirects.
# Set to your deployed site in production and when sending real emails from local dev.
NEXT_PUBLIC_APP_URL=https://aquaticsempowered.vercel.app

# REQUIRED (MVP)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PROJECT_ID=

# REQUIRED (MVP)
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# OPTIONAL (post-MVP — feat/stripe-checkout)
# List prices: Free $0 · Essential $399/mo · Professional $699/mo (see src/lib/marketing/publicPricing.ts)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_ESSENTIAL_MONTHLY=
STRIPE_PRICE_ESSENTIAL_ANNUAL=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_ANNUAL=
STRIPE_PRICE_FOUNDER_ANNUAL=
# 50% off list price at checkout — run: npm run stripe:sync-catalog -- --apply
STRIPE_PROMO_COUPON_ID=

# OPTIONAL (Phase 3)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# OPTIONAL — Community AI energy audit (Programs tab beta)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# OPTIONAL — Sensor telemetry ingest (Bearer token for POST /api/sensors/ingest)
SENSOR_INGEST_SECRET=

# OPTIONAL (recommended for production) — distributed rate limiting via Upstash Redis.
# When unset, rate limiting falls back to a per-instance in-memory store.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# OPTIONAL (recommended)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# Dev-only: enable /dev/sentry-test page in production (default off)
NEXT_PUBLIC_ENABLE_DEV_ROUTES=false
